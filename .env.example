# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Optional: required for draft preview and seed script writes
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Webhook / on-demand revalidation secret (also set as webhook Secret in Sanity Manage)
SANITY_REVALIDATE_SECRET=

# Site URL for draft mode redirects and webhook target
NEXT_PUBLIC_SITE_URL=https://bluephoenixeyecare.sintyz.com

# After deploy, run: npm run setup:sanity:webhook
# Or create webhook manually in Sanity Manage -> API -> Webhooks pointing to:
# POST https://your-domain.com/api/revalidate
